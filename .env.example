# AWS Configuration
# Copy this file to .env and fill in your AWS credentials

# AWS Region
VITE_AWS_REGION=us-east-1

# AWS Cognito Configuration
VITE_AWS_COGNITO_USER_POOL_ID=your-user-pool-id
VITE_AWS_COGNITO_CLIENT_ID=your-client-id

# AWS S3 Configuration
VITE_AWS_S3_BUCKET=your-bucket-name
VITE_AWS_S3_REGION=us-east-1

# AWS DynamoDB Configuration
VITE_AWS_DYNAMODB_TABLE=agrofeed-content
VITE_AWS_DYNAMODB_REGION=us-east-1

# AWS Credentials (for development)
# In production, use IAM roles or environment variables
VITE_AWS_ACCESS_KEY_ID=your-access-key-id
VITE_AWS_SECRET_ACCESS_KEY=your-secret-access-key
